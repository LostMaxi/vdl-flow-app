# VDL-FLOW Generator API Keys
# 複製此檔案為 .env.local，填入真實 key 後重啟 dev server

# ── Google AI (Gemini + VEO) ──────────────────────────────────
# 取得: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# ── Runway Gen-3 ─────────────────────────────────────────────
# 取得: https://app.runwayml.com/settings → API Keys
VITE_RUNWAY_API_KEY=

# ── Kling v2 (Kuaishou) ───────────────────────────────────────
# 取得: https://klingai.com/developer
VITE_KLING_ACCESS_KEY=
VITE_KLING_SECRET_KEY=

# ── Stability AI (SDXL) ───────────────────────────────────────
# 取得: https://platform.stability.ai/account/keys
VITE_STABILITY_API_KEY=

# ── ComfyUI 本地 GPU (RTX 2070 支援) ────────────────────────────
# 啟動 ComfyUI: python main.py --listen 0.0.0.0
# 模型放置: ComfyUI/models/checkpoints/
VITE_COMFYUI_URL=http://127.0.0.1:8188
VITE_COMFYUI_MODEL=sd_xl_base_1.0.safetensors

# ── 預設生成端 ─────────────────────────────────────────────────
# 圖片: comfyui (本地GPU) | pollinations (零金鑰) | stable_diffusion_xl | google_gemini_imagen
# 影片: google_flow_veo | runway_gen3 | kling_v2
VITE_DEFAULT_IMAGE_GENERATOR=comfyui
VITE_DEFAULT_VIDEO_GENERATOR=google_flow_veo
