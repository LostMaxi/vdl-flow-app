{
  "name": "vdl-flow-app",
  "version": "1.0.0",
  "description": "VDL-FLOW Visual Narrative Closed-Loop Animation Pipeline",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "ext:build": "tsc && vite build --config vite.ext.config.ts && cp chrome-ext/manifest.json dist-ext/manifest.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "animejs": "^3.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^1.6.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.3.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  }
}
